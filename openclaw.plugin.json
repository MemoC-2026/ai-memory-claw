{
  "id": "ai-memory-claw",
  "name": "AI Memory Claw",
  "description": "AI渐进式记忆系统 - 无感运行版 (多Agent支持)",
  "uiHints": {
    "dataDir": {
      "label": "数据存储目录",
      "placeholder": "~/.ai-memory-claw/data",
      "help": "记忆数据存储的目录路径，支持 {agentName} 变量"
    },
    "autoRecall": {
      "label": "自动召回",
      "help": "对话前自动搜索并注入相关记忆"
    },
    "autoCapture": {
      "label": "自动捕获",
      "help": "对话后自动生成记忆"
    },
    "captureStrategy": {
      "label": "捕获策略",
      "help": "always=每次都存, selective=关键词匹配才存"
    },
    "autoRecallInNewSession": {
      "label": "新会话召回",
      "help": "新会话（首次对话）时自动注入1条最相关记忆"
    },
    "newSessionMemoryLimit": {
      "label": "新会话召回数量",
      "help": "新会话时注入的记忆数量（建议1条）"
    },
    "manualTriggerEnabled": {
      "label": "手动触发",
      "help": "用户消息包含关键词时触发召回"
    },
    "manualRecallLimit": {
      "label": "手动召回数量",
      "help": "手动触发时注入的记忆数量"
    },
    "recallThreshold": {
      "label": "召回阈值",
      "help": "相似度阈值，0-1之间，越高越严格"
    },
    "recallLimit": {
      "label": "召回数量",
      "help": "每次召回的记忆数量上限"
    },
    "enableForget": {
      "label": "启用遗忘",
      "help": "自动删除低价值记忆"
    },
    "enableIntegration": {
      "label": "启用整合",
      "help": "自动合并相似记忆"
    },
    "agentName": {
      "label": "Agent名称",
      "placeholder": "default",
      "help": "Agent标识符，用于记忆隔离。不同Agent使用不同目录存储记忆"
    },
    "sharedEnabled": {
      "label": "启用共享记忆",
      "help": "是否启用跨Agent共享记忆功能"
    },
    "sharedDir": {
      "label": "共享记忆目录",
      "placeholder": "~/.ai-memory-claw/shared",
      "help": "共享记忆存储目录，所有Agent都能访问"
    },
    "fallbackToDefault": {
      "label": "回退到默认目录",
      "help": "当Agent目录不存在时，回退到默认data目录（兼容旧版本）"
    }
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "dataDir": {
        "type": "string",
        "default": "~/.ai-memory-claw/data"
      },
      "autoRecall": {
        "type": "boolean",
        "default": true
      },
      "autoCapture": {
        "type": "boolean",
        "default": true
      },
      "captureStrategy": {
        "type": "string",
        "enum": ["always", "selective"],
        "default": "always"
      },
      "autoRecallInNewSession": {
        "type": "boolean",
        "default": true
      },
      "newSessionMemoryLimit": {
        "type": "number",
        "default": 1,
        "minimum": 1,
        "maximum": 5
      },
      "manualTriggerEnabled": {
        "type": "boolean",
        "default": true
      },
      "manualTriggerKeywords": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["记得", "之前", "上次", "以前", "查一下", "看看之前的记忆", "用一下之前的", "参考之前的", "以前是怎么做的", "你还记得吗", "记忆里", "历史上", "之前那次"]
      },
      "manualRecallLimit": {
        "type": "number",
        "default": 3,
        "minimum": 1,
        "maximum": 10
      },
      "recallThreshold": {
        "type": "number",
        "default": 0.6,
        "minimum": 0,
        "maximum": 1
      },
      "recallLimit": {
        "type": "number",
        "default": 2,
        "minimum": 1,
        "maximum": 10
      },
      "captureMaxChars": {
        "type": "number",
        "default": 500,
        "minimum": 100,
        "maximum": 2000
      },
      "enableSummary": {
        "type": "boolean",
        "default": true
      },
      "enableForget": {
        "type": "boolean",
        "default": true
      },
      "enableIntegration": {
        "type": "boolean",
        "default": true
      },
      "forgetIntervalDays": {
        "type": "number",
        "default": 7,
        "minimum": 1,
        "maximum": 30
      },
      "integrationThreshold": {
        "type": "number",
        "default": 0.8,
        "minimum": 0.5,
        "maximum": 1
      },
      "agentName": {
        "type": "string",
        "default": "default"
      },
      "sharedEnabled": {
        "type": "boolean",
        "default": true
      },
      "sharedDir": {
        "type": "string",
        "default": "~/.ai-memory-claw/shared"
      },
      "fallbackToDefault": {
        "type": "boolean",
        "default": true
      }
    }
  }
}
